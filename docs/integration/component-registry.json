{
  "$schema": "Titan component registry — machine-readable catalog for MCP code generation",
  "package": "titan-compositions",
  "version": "0.2.0",
  "css": "titan-compositions/styles",
  "peerDependencies": [
    "react >=18.0.0",
    "react-dom >=18.0.0",
    "react-aria-components >=1.0.0",
    "lucide-react >=0.460.0",
    "@tabler/icons-react >=3.0.0",
    "@internationalized/date >=3.0.0"
  ],
  "themeSetup": {
    "tokens": "tokens/css/titan.css",
    "themes": [
      "tokens/themes/_insights.css",
      "tokens/themes/_audiense.css",
      "tokens/themes/_neutral.css",
      "tokens/themes/_demand.css",
      "tokens/themes/_linkedin.css",
      "tokens/themes/_tweetbinder.css",
      "tokens/themes/_brand.css"
    ],
    "activation": "<html data-theme=\"insights\">"
  },
  "components": {
    "TitanAvatar": {
      "import": "import { TitanAvatar } from 'titan-compositions'",
      "description": "User avatar circle. Shows the first letter of account name, or a user icon if no account is provided.",
      "props": {
        "account": { "type": "string", "required": false, "description": "User name — first letter is rendered as the avatar initial." },
        "icon": { "type": "ReactNode", "required": false, "description": "Custom icon to show when no account is provided." },
        "aria-label": { "type": "string", "required": false }
      },
      "slots": [],
      "category": "display"
    },
    "TitanBadge": {
      "import": "import { TitanBadge, TitanBadgeAnchor } from 'titan-compositions'",
      "description": "Notification count badge. TitanBadge renders the count pill; TitanBadgeAnchor positions it at the top-right corner of any child element.",
      "props": {
        "count": { "type": "number", "required": true, "description": "Notification count. Hidden when 0." },
        "max": { "type": "number", "required": false, "default": "99", "description": "Maximum displayed count. Exceeding shows 'max+'." }
      },
      "slots": [],
      "composableWith": ["TitanIconButton", "TitanNotificationsMenu"],
      "category": "feedback"
    },
    "TitanBadgeAnchor": {
      "import": "import { TitanBadgeAnchor } from 'titan-compositions'",
      "description": "Wrapper that positions a TitanBadge at the top-right corner of its child element (typically an icon button).",
      "props": {
        "count": { "type": "number", "required": true },
        "max": { "type": "number", "required": false, "default": "99" },
        "children": { "type": "ReactNode", "required": true, "description": "Element to anchor the badge to" }
      },
      "slots": ["children"],
      "composableWith": ["TitanIconButton"],
      "category": "feedback"
    },
    "TitanButton": {
      "import": "import { TitanButton, TitanButtonVariants } from 'titan-compositions'",
      "description": "Standard button with baseline-compatible variants and optional leading icon. Wraps React Aria Button.",
      "props": {
        "variant": { "type": "'primary' | 'secondary' | 'tertiary' | 'link' | 'text' | 'delete' | 'delete-secondary'", "default": "'primary'", "required": false },
        "icon": { "type": "ReactNode", "required": false, "description": "Leading icon (renders with-icon layout)" },
        "children": { "type": "ReactNode", "required": false, "description": "Button label text" },
        "className": { "type": "string", "required": false },
        "isDisabled": { "type": "boolean", "required": false },
        "onPress": { "type": "() => void", "required": false }
      },
      "slots": ["icon", "children"],
      "category": "action"
    },
    "TitanButtonGroup": {
      "import": "import { TitanButtonGroup, TitanIndividualButton } from 'titan-compositions'",
      "description": "Segmented toggle button group with single selection (radio behavior). Uses React Aria ToggleButtonGroup. Supports horizontal and vertical orientations.",
      "props": {
        "children": { "type": "ReactNode", "required": true, "description": "TitanIndividualButton children" },
        "orientation": { "type": "'horizontal' | 'vertical'", "default": "'horizontal'", "required": false },
        "className": { "type": "string", "required": false }
      },
      "slots": ["children"],
      "composableWith": ["TitanIndividualButton"],
      "category": "action"
    },
    "TitanCollapsible": {
      "import": "import { TitanCollapsible } from 'titan-compositions'",
      "description": "Expandable/collapsible content section with a header toggle button and chevron indicator.",
      "props": {
        "children": { "type": "ReactNode", "required": true, "description": "Content to show/hide" },
        "title": { "type": "ReactNode", "required": false, "description": "Header label" },
        "isCollapsed": { "type": "boolean", "required": false, "description": "Controlled collapsed state" },
        "onChange": { "type": "(isCollapsed: boolean) => void", "required": false },
        "aria-label": { "type": "string", "required": false }
      },
      "slots": ["children"],
      "category": "layout"
    },
    "TitanDivider": {
      "import": "import { TitanDivider } from 'titan-compositions'",
      "description": "Horizontal rule divider styled with Titan tokens.",
      "props": {
        "className": { "type": "string", "required": false }
      },
      "slots": [],
      "category": "layout"
    },
    "TitanIconButton": {
      "import": "import { TitanIconButton, TitanIconButtonVariants } from 'titan-compositions'",
      "description": "Icon-only button with baseline-compatible variants. Must have aria-label.",
      "props": {
        "variant": { "type": "'primary' | 'secondary' | 'base' | 'base-l' | 'neutral-base' | 'neutral-base-l' | 'ghost' | 'delete'", "default": "'primary'", "required": false },
        "children": { "type": "ReactNode", "required": true, "description": "Icon element (e.g. Lucide icon)" },
        "className": { "type": "string", "required": false },
        "aria-label": { "type": "string", "required": true, "description": "Accessible name (mandatory for icon-only)" },
        "isDisabled": { "type": "boolean", "required": false },
        "onPress": { "type": "() => void", "required": false }
      },
      "slots": ["children"],
      "category": "action"
    },
    "TitanDialog": {
      "import": "import { TitanDialog } from 'titan-compositions'",
      "description": "Dialog supports trigger mode and controlled mode (isOpen/onOpenChange/onClose). Wraps React Aria Dialog/Modal.",
      "props": {
        "triggerLabel": { "type": "string", "required": false, "description": "Optional label for trigger mode." },
        "title": { "type": "string", "required": false },
        "body": { "type": "ReactNode", "required": false, "description": "Dialog body content — accepts any JSX (forms, text, etc.)" },
        "leftAction": { "type": "ReactNode", "required": false, "description": "Left footer action (e.g. Cancel button)" },
        "rightAction": { "type": "ReactNode", "required": false, "description": "Right footer action (e.g. Save/Delete button)" },
        "isOpen": { "type": "boolean", "required": false },
        "onOpenChange": { "type": "(isOpen: boolean) => void", "required": false },
        "onClose": { "type": "() => void", "required": false },
        "aria-label": { "type": "string", "required": false },
        "children": { "type": "ReactNode", "required": false }
      },
      "slots": ["body", "leftAction", "rightAction"],
      "composableWith": ["TitanButton", "TitanInputField", "TitanTextareaField", "TitanSelect", "TitanCheckboxField", "TitanRadioGroupField", "TitanSwitchField"],
      "category": "overlay"
    },
    "TitanDrawer": {
      "import": "import { TitanDrawer } from 'titan-compositions'",
      "description": "Right-side slide-in panel with trigger mode or controlled mode (isOpen/onOpenChange/onClose). Wraps React Aria Dialog/Modal.",
      "props": {
        "triggerLabel": { "type": "string", "required": false, "description": "Label for default trigger button." },
        "trigger": { "type": "ReactNode", "required": false, "description": "Custom trigger element." },
        "title": { "type": "string", "required": true },
        "children": { "type": "ReactNode", "required": true, "description": "Drawer body content" },
        "isOpen": { "type": "boolean", "required": false },
        "onOpenChange": { "type": "(isOpen: boolean) => void", "required": false },
        "onClose": { "type": "() => void", "required": false }
      },
      "slots": ["children"],
      "composableWith": ["TitanInputField", "TitanTextareaField", "TitanSelect", "TitanCheckboxField", "TitanRadioGroupField", "TitanSwitchField", "TitanButton"],
      "category": "overlay"
    },
    "TitanInputField": {
      "import": "import { TitanInputField, TitanTextInput } from 'titan-compositions'",
      "description": "Text input field with optional label, hint, counter, leading/trailing icons, and error message. Wraps React Aria TextField.",
      "props": {
        "label": { "type": "string", "required": false },
        "placeholder": { "type": "string", "required": false },
        "hint": { "type": "string", "required": false, "description": "Helper text below the input" },
        "hintMessage": { "type": "string", "required": false, "description": "Alias for hint." },
        "counter": { "type": "string", "required": false, "description": "Character counter text (e.g. '0/60')" },
        "leadingIcon": { "type": "ReactNode", "required": false, "description": "Icon before input text" },
        "startIcon": { "type": "ReactNode", "required": false, "description": "Alias for leadingIcon." },
        "trailingIcon": { "type": "ReactNode", "required": false, "description": "Icon after input text" },
        "endIcon": { "type": "ReactNode", "required": false, "description": "Alias for trailingIcon." },
        "onEndIconClick": { "type": "() => void", "required": false },
        "onClear": { "type": "() => void", "required": false },
        "maxLength": { "type": "number", "required": false },
        "onChange": { "type": "(value: string) => void", "required": false },
        "errorMessage": { "type": "string", "required": false, "description": "Error text shown when isInvalid is true" },
        "isInvalid": { "type": "boolean", "required": false },
        "isDisabled": { "type": "boolean", "required": false },
        "isRequired": { "type": "boolean", "required": false },
        "className": { "type": "string", "required": false }
      },
      "slots": ["leadingIcon", "trailingIcon"],
      "category": "form"
    },
    "TitanTextareaField": {
      "import": "import { TitanTextareaField, TitanTextArea } from 'titan-compositions'",
      "description": "Multi-line text input with optional label, hint, counter, leading icon, clear button, auto-expand, and error. Wraps React Aria TextField + TextArea.",
      "props": {
        "label": { "type": "string", "required": false },
        "placeholder": { "type": "string", "required": false },
        "hint": { "type": "string", "required": false },
        "hintMessage": { "type": "string", "required": false, "description": "Alias for hint." },
        "counter": { "type": "string", "required": false },
        "leadingIcon": { "type": "ReactNode", "required": false, "description": "Icon displayed at the start of the textarea" },
        "startIcon": { "type": "ReactNode", "required": false, "description": "Alias for leadingIcon." },
        "endIcon": { "type": "ReactNode", "required": false },
        "onEndIconClick": { "type": "() => void", "required": false },
        "onClear": { "type": "() => void", "required": false, "description": "Callback when clear button is pressed. Shows an X icon when provided." },
        "autoExpand": { "type": "boolean", "required": false, "default": "false", "description": "Textarea grows vertically as content increases" },
        "maxLength": { "type": "number", "required": false },
        "onChange": { "type": "(value: string) => void", "required": false },
        "errorMessage": { "type": "string", "required": false },
        "isInvalid": { "type": "boolean", "required": false },
        "isDisabled": { "type": "boolean", "required": false },
        "isRequired": { "type": "boolean", "required": false },
        "className": { "type": "string", "required": false }
      },
      "slots": ["leadingIcon"],
      "category": "form"
    },
    "TitanCheckboxField": {
      "import": "import { TitanCheckboxField } from 'titan-compositions'",
      "description": "Single checkbox with label. Wraps React Aria Checkbox.",
      "props": {
        "label": { "type": "string", "required": true },
        "isDisabled": { "type": "boolean", "default": "false", "required": false },
        "defaultSelected": { "type": "boolean", "default": "false", "required": false }
      },
      "slots": [],
      "category": "form"
    },
    "TitanRadioGroupField": {
      "import": "import { TitanRadioGroupField } from 'titan-compositions'",
      "description": "Radio group with label and list of options. Wraps React Aria RadioGroup.",
      "props": {
        "label": { "type": "string", "required": true },
        "options": { "type": "TitanRadioOption[]", "required": true, "description": "Array of { value, label, disabled? }" },
        "defaultValue": { "type": "string", "required": false }
      },
      "slots": [],
      "relatedTypes": {
        "TitanRadioOption": { "value": "string", "label": "string", "disabled?": "boolean" }
      },
      "category": "form"
    },
    "TitanSwitchField": {
      "import": "import { TitanSwitchField } from 'titan-compositions'",
      "description": "Toggle switch with label. Wraps React Aria Switch.",
      "props": {
        "label": { "type": "string", "required": true },
        "isDisabled": { "type": "boolean", "default": "false", "required": false },
        "defaultSelected": { "type": "boolean", "default": "false", "required": false }
      },
      "slots": [],
      "category": "form"
    },
    "TitanFormControlsGroup": {
      "import": "import { TitanFormControlsGroup } from 'titan-compositions'",
      "description": "3-column grid container for form controls (checkboxes, radios, switches).",
      "props": {
        "children": { "type": "ReactNode", "required": true }
      },
      "slots": ["children"],
      "composableWith": ["TitanCheckboxField", "TitanRadioGroupField", "TitanSwitchField"],
      "category": "form"
    },
    "TitanSelect": {
      "import": "import { TitanSelect } from 'titan-compositions'",
      "description": "Dropdown select with label, trigger button, popover list, open-state chevron, and hint/error support. Wraps React Aria Select.",
      "props": {
        "label": { "type": "string", "required": false },
        "options": { "type": "TitanSelectOption[]", "required": true, "description": "Array of { id, label, icon?, disabled? }" },
        "defaultSelectedKey": { "type": "string", "required": false },
        "selectedKey": { "type": "string", "required": false },
        "onSelectionChange": { "type": "(key: Key | null) => void", "required": false },
        "placeholder": { "type": "string", "required": false },
        "hintMessage": { "type": "string", "required": false },
        "errorMessage": { "type": "string", "required": false },
        "isDisabled": { "type": "boolean", "default": "false", "required": false },
        "isRequired": { "type": "boolean", "default": "false", "required": false },
        "name": { "type": "string", "required": false },
        "aria-label": { "type": "string", "required": false }
      },
      "slots": [],
      "relatedTypes": {
        "TitanSelectOption": { "id": "string", "label": "string", "icon?": "ReactNode", "disabled?": "boolean" }
      },
      "category": "form"
    },
    "TitanMenuDropdown": {
      "import": "import { TitanMenuDropdown } from 'titan-compositions'",
      "description": "Dropdown menu with cascading submenu support. Wraps React Aria MenuTrigger/Menu.",
      "props": {
        "triggerLabel": { "type": "string", "default": "'Open menu'", "required": false },
        "triggerIcon": { "type": "ReactNode", "required": false, "description": "Icon for icon-only trigger mode" },
        "iconOnly": { "type": "boolean", "default": "false", "required": false, "description": "When true, renders icon-only ghost trigger" },
        "placement": { "type": "'bottom start' | 'bottom end'", "default": "'bottom start'", "required": false },
        "items": { "type": "TitanMenuOption[]", "required": true, "description": "Array of menu items with optional children for cascading" },
        "onAction": { "type": "(id: string) => void", "required": false }
      },
      "slots": [],
      "relatedTypes": {
        "TitanMenuOption": { "id": "string", "label": "string", "icon?": "ReactNode", "disabled?": "boolean", "destructive?": "boolean", "mcp?": "boolean", "user?": "boolean", "children?": "TitanMenuOption[]" }
      },
      "category": "navigation"
    },
    "TitanTabs": {
      "import": "import { TitanTabs } from 'titan-compositions'",
      "description": "Tab list with panels. Wraps React Aria Tabs. Supports horizontal (pill-style) and vertical (sidebar-style with right accent border) orientations, plus overflow scroll mode.",
      "props": {
        "items": { "type": "TitanTabItem[]", "required": true, "description": "Array of { id, label, content, disabled? }" },
        "defaultSelectedKey": { "type": "string", "required": false },
        "selectedKey": { "type": "Key", "required": false },
        "onSelectionChange": { "type": "(key: Key) => void", "required": false },
        "overflow": { "type": "boolean", "default": "false", "required": false, "description": "Enables horizontal scroll when tabs overflow (horizontal only)" },
        "orientation": { "type": "'horizontal' | 'vertical'", "default": "'horizontal'", "required": false, "description": "Horizontal = pill tabs in a row. Vertical = sidebar tabs with right accent border." },
        "ariaLabel": { "type": "string", "default": "'Tabs'", "required": false }
      },
      "slots": [],
      "relatedTypes": {
        "TitanTabItem": { "id": "string", "label": "string", "content": "ReactNode", "disabled?": "boolean" }
      },
      "category": "navigation"
    },
    "TitanPagination": {
      "import": "import { TitanPagination } from 'titan-compositions'",
      "description": "Page navigation with numbered pages, ellipsis support, and prev/next buttons.",
      "props": {
        "ariaLabel": { "type": "string", "required": false },
        "aria-label": { "type": "string", "required": false },
        "pages": { "type": "(number | 'ellipsis')[]", "required": false, "description": "Page numbers and ellipsis markers" },
        "currentPage": { "type": "number", "required": true },
        "totalPages": { "type": "number", "required": false },
        "setPage": { "type": "(page: number) => void", "required": false },
        "previousDisabled": { "type": "boolean", "default": "false", "required": false },
        "nextDisabled": { "type": "boolean", "default": "false", "required": false },
        "onPageChange": { "type": "(page: number) => void", "required": false },
        "onPrevious": { "type": "() => void", "required": false },
        "onNext": { "type": "() => void", "required": false }
      },
      "slots": [],
      "category": "navigation"
    },
    "TitanBreadcrumb": {
      "import": "import { TitanBreadcrumb } from 'titan-compositions'",
      "description": "Breadcrumb navigation with clickable ancestors and non-interactive current item. Supports collapse (ellipsis dropdown) when items exceed maxVisible. Wraps React Aria Breadcrumbs.",
      "props": {
        "items": { "type": "TitanBreadcrumbItem[]", "required": true, "description": "Ancestor breadcrumb items" },
        "currentLabel": { "type": "string", "required": true, "description": "Current page label (rendered as non-interactive with aria-current='page')" },
        "maxVisible": { "type": "number", "required": false, "default": "5", "description": "Max visible items before collapse. Middle items collapse into an ellipsis dropdown." },
        "ariaLabel": { "type": "string", "default": "'Breadcrumb'", "required": false }
      },
      "slots": [],
      "relatedTypes": {
        "TitanBreadcrumbItem": { "id": "string", "label": "string", "icon?": "ReactNode", "selected?": "boolean", "disabled?": "boolean", "onPress?": "() => void" }
      },
      "composableWith": ["TitanMenuDropdown"],
      "category": "navigation"
    },
    "TitanNavbar": {
      "import": "import { TitanNavbar } from 'titan-compositions'",
      "description": "Application navbar with themed logo, icon actions (Grip, Bell, Handshake, CircleHelp, Settings, Sparkles), and user avatar + menu. Logo auto-switches based on theme.",
      "props": {
        "theme": { "type": "'demand' | 'audiense' | 'neutral' | 'insights' | 'linkedin' | 'tweetbinder' | 'connect' | 'brand'", "default": "'insights'", "required": false },
        "userInitial": { "type": "string", "default": "'A'", "required": false },
        "logoAlt": { "type": "string", "default": "'Product logo'", "required": false },
        "logoBasePath": { "type": "string", "default": "CDN URL (jsdelivr)", "required": false, "description": "Base path/URL for logo assets. Defaults to CDN. Pass '/assets/logos' for local." },
        "onChangeProduct": { "type": "() => void", "required": false },
        "onNotifications": { "type": "() => void", "required": false },
        "onSupport": { "type": "() => void", "required": false },
        "onHelp": { "type": "() => void", "required": false },
        "onSettings": { "type": "() => void", "required": false },
        "onFeaturedAction": { "type": "() => void", "required": false },
        "onUserMenu": { "type": "() => void", "required": false }
      },
      "slots": [],
      "logoMap": {
        "cdnBase": "https://cdn.jsdelivr.net/gh/angelcreative/titan-foundations@main/public/assets/logos",
        "byTheme": {
          "insights": "logo-insights.svg",
          "audiense": "logo-audiense.svg",
          "demand": "logo-demand.svg",
          "neutral": "logo-audiense.svg",
          "linkedin": "logo-linkedin.svg",
          "tweetbinder": "logo-tweetbinder.svg",
          "connect": "logo-connect.svg",
          "brand": "logo-audiense.svg"
        },
        "usage": "<img src=\"{cdnBase}/{byTheme[theme]}\" alt=\"Product logo\" style=\"max-height: 30px; width: auto;\" />"
      },
      "category": "shell"
    },
    "TitanCardGrid": {
      "import": "import { TitanCardGrid } from 'titan-compositions'",
      "description": "16-column layout grid. Use with TitanCard children.",
      "props": {
        "children": { "type": "ReactNode", "required": true, "description": "TitanCard elements" }
      },
      "slots": ["children"],
      "composableWith": ["TitanCard"],
      "category": "layout"
    },
    "TitanCard": {
      "import": "import { TitanCard } from 'titan-compositions'",
      "description": "Card with configurable column span (4/8/12/16) for use inside TitanCardGrid.",
      "props": {
        "children": { "type": "ReactNode", "required": true },
        "span": { "type": "4 | 8 | 12 | 16", "default": "16", "required": false },
        "className": { "type": "string", "required": false }
      },
      "slots": ["children"],
      "composableWith": ["TitanTable", "TitanInputField", "TitanButton", "TitanMenuDropdown", "TitanSelect"],
      "category": "layout"
    },
    "TitanTable": {
      "import": "import { TitanTable, TitanTableHeader, TitanColumn, TitanTableBody, TitanRow, TitanCell } from 'titan-compositions'",
      "description": "Accessible data table (React Aria). Use TitanTable + TitanTableHeader/TitanColumn + TitanTableBody/TitanRow/TitanCell. Supports sortDescriptor/onSortChange, sticky header, resizable columns, drag-and-drop, selection. Optional cell helpers: TitanTableCellDate, TitanTableCellInitials, TitanTableCellActions, TitanTableCellStatus.",
      "props": {
        "aria-label": { "type": "string", "required": true },
        "sortDescriptor": { "type": "{ column: Key, direction: 'ascending' | 'descending' }", "required": false },
        "onSortChange": { "type": "(descriptor: SortDescriptor) => void", "required": false },
        "selectionMode": { "type": "'none' | 'single' | 'multiple'", "required": false },
        "selectedKeys": { "type": "Iterable<Key>", "required": false },
        "onSelectionChange": { "type": "(keys: Selection) => void", "required": false }
      },
      "slots": ["TitanTableHeader (columns + render Column)", "TitanTableBody (items + render Row/Cell)"],
      "relatedTypes": {
        "TitanColumn": "id (string), allowsSorting?, isRowHeader?, alignment? ('left'|'center'|'right'), numericSort?, sortIconPosition? ('left'|'right'), showInfoIcon?, infoIconAriaLabel?. Header variants: [sort] label, label [info], [sort] label [info], label. Only sortable columns get sorted background.",
        "TitanRow": "id (row key), columns for cell render",
        "TitanCell": "wraps cell content; supports alignment ('left'|'center'|'right'); use col.render(row) when using column config"
      },
      "category": "data"
    },
    "TitanTableCellDate": {
      "import": "import { TitanTableCellDate } from 'titan-compositions'",
      "description": "Table cell helper: renders a date with a calendar icon. Accepts Date objects, ISO strings, or timestamps. Default format: 'Nov 15, 2025'. Use inside TitanCell.",
      "props": {
        "value": { "type": "Date | string | number", "required": true, "description": "Date object, ISO string, or timestamp" },
        "format": { "type": "(d: Date) => string", "required": false, "description": "Custom date formatter. Default: en-US short (e.g. 'Nov 15, 2025')" },
        "className": { "type": "string", "required": false }
      },
      "slots": [],
      "category": "data"
    },
    "TitanTableCellInitials": {
      "import": "import { TitanTableCellInitials } from 'titan-compositions'",
      "description": "Table cell helper: renders initials in a colored circle. Pass initials directly or a name to auto-derive them. Color is stable per seed. Use inside TitanCell.",
